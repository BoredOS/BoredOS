set(CMAKE_SYSTEM_NAME Generic)
set(CMAKE_SYSTEM_PROCESSOR x86_64)
set(CMAKE_TRY_COMPILE_TARGET_TYPE STATIC_LIBRARY)
set(BOREDOS ON CACHE BOOL "Build OpenTTD for BoredOS")

set(BOREDOS_REPO_ROOT "${CMAKE_CURRENT_LIST_DIR}/../../../../..")
set(BOREDOS_USERLAND_ROOT "${BOREDOS_REPO_ROOT}/src/userland")
set(BOREDOS_SDK_ROOT "${BOREDOS_USERLAND_ROOT}/sdk")
set(BOREDOS_OPENTTD_PORT_ROOT "${BOREDOS_USERLAND_ROOT}/games/openttd")
set(BOREDOS_LIBCXX_ROOT "/home/linuxbrew/.linuxbrew/Cellar/llvm/22.1.5")

set(CMAKE_C_COMPILER x86_64-elf-gcc CACHE FILEPATH "")
set(CMAKE_CXX_COMPILER x86_64-elf-g++ CACHE FILEPATH "")
set(CMAKE_AR x86_64-elf-ar CACHE FILEPATH "")
set(CMAKE_RANLIB x86_64-elf-ranlib CACHE FILEPATH "")

set(CMAKE_FIND_ROOT_PATH "${BOREDOS_SDK_ROOT}")
set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)

set(CMAKE_C_FLAGS_INIT "-ffreestanding -fno-stack-protector -fno-stack-check -fno-lto -fno-pie -m64 -march=x86-64 -mno-red-zone -mstackrealign -DBOREDOS -I${BOREDOS_USERLAND_ROOT} -I${BOREDOS_USERLAND_ROOT}/libc -I${BOREDOS_SDK_ROOT}/include")
set(CMAKE_CXX_FLAGS_INIT "-std=gnu++23 -ffreestanding -fno-stack-protector -fno-stack-check -fno-lto -fno-pie -m64 -march=x86-64 -mno-red-zone -mstackrealign -nostdinc++ -DBOREDOS -DJSON_NO_IO -DFMT_USE_LOCALE=0 -D_LIBCPP_DISABLE_EXTERN_TEMPLATE -Wno-uninitialized -Wno-maybe-uninitialized -Wno-alloc-size-larger-than -Wno-array-bounds -Wno-free-nonheap-object -Wno-suggest-override -Wno-unused-parameter -isystem ${BOREDOS_OPENTTD_PORT_ROOT}/libcxx_boredos -isystem ${BOREDOS_LIBCXX_ROOT}/include/c++/v1 -isystem ${BOREDOS_USERLAND_ROOT} -isystem ${BOREDOS_USERLAND_ROOT}/libc -isystem ${BOREDOS_SDK_ROOT}/include")
set(CMAKE_C_FLAGS "${CMAKE_C_FLAGS_INIT}" CACHE STRING "" FORCE)
set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS_INIT}" CACHE STRING "" FORCE)
set(CMAKE_EXE_LINKER_FLAGS_INIT "-nostdlib -static -no-pie -Wl,-Ttext=0x40000000 -Wl,--no-dynamic-linker -Wl,-z,text -Wl,-z,noexecstack -Wl,-z,max-page-size=0x1000 -Wl,--allow-multiple-definition")
set(CMAKE_EXE_LINKER_FLAGS "${CMAKE_EXE_LINKER_FLAGS_INIT}" CACHE STRING "" FORCE)
set(CMAKE_C_STANDARD_LIBRARIES_INIT "${BOREDOS_SDK_ROOT}/lib/libboredos.a")
set(CMAKE_CXX_STANDARD_LIBRARIES_INIT "${BOREDOS_SDK_ROOT}/lib/libboredos.a ${BOREDOS_LIBCXX_ROOT}/lib/libc++.a ${BOREDOS_LIBCXX_ROOT}/lib/libc++abi.a -lgcc")
set(CMAKE_C_STANDARD_LIBRARIES "${CMAKE_C_STANDARD_LIBRARIES_INIT}" CACHE STRING "" FORCE)
set(CMAKE_CXX_STANDARD_LIBRARIES "${CMAKE_CXX_STANDARD_LIBRARIES_INIT}" CACHE STRING "" FORCE)

set(CMAKE_THREAD_LIBS_INIT "" CACHE STRING "")
set(CMAKE_HAVE_THREADS_LIBRARY 1 CACHE INTERNAL "")
set(CMAKE_USE_WIN32_THREADS_INIT 0 CACHE INTERNAL "")
set(CMAKE_USE_PTHREADS_INIT 0 CACHE INTERNAL "")
set(Threads_FOUND TRUE CACHE BOOL "")
